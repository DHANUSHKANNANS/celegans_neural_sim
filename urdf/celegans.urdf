<?xml version="1.0"?>
<robot name="celegans" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Materials -->
  <material name="worm_body">
    <color rgba="0.3 0.7 0.3 0.9"/>
  </material>
  <material name="worm_head">
    <color rgba="0.4 0.9 0.4 1.0"/>
  </material>
  <material name="worm_dark">
    <color rgba="0.15 0.45 0.15 0.9"/>
  </material>

  <!-- World fixed link -->
  <link name="world"/>

  <joint name="world_to_base" type="floating">
    <parent link="world"/>
    <child  link="segment_0"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════
       Segment macro: 12 body segments
       Radius tapers from 0.018 (head) to 0.010 (tail)
       Length per segment: 0.05 m
  ═══════════════════════════════════ -->

  <!-- Segment 0 (HEAD) -->
  <link name="segment_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.018" length="0.048"/></geometry>
      <material name="worm_head"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.018" length="0.048"/></geometry>
    </collision>
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/>
    </inertial>
  </link>

  <!-- Segments 1-11 with revolute joints -->
  <!-- Segment 1 -->
  <link name="segment_1">
    <visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.018" length="0.048"/></geometry>
      <material name="worm_body"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.018" length="0.048"/></geometry></collision>
    <inertial><mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial>
  </link>
  <joint name="joint_0" type="revolute">
    <parent link="segment_0"/><child link="segment_1"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <!-- Segment 2 -->
  <link name="segment_2">
    <visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.017" length="0.048"/></geometry>
      <material name="worm_body"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.017" length="0.048"/></geometry></collision>
    <inertial><mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial>
  </link>
  <joint name="joint_1" type="revolute">
    <parent link="segment_1"/><child link="segment_2"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <!-- Segment 3 -->
  <link name="segment_3">
    <visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.016" length="0.048"/></geometry>
      <material name="worm_body"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry><cylinder radius="0.016" length="0.048"/></geometry></collision>
    <inertial><mass value="0.001"/>
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial>
  </link>
  <joint name="joint_2" type="revolute">
    <parent link="segment_2"/><child link="segment_3"/>
    <origin xyz="-0.05 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <!-- Segments 4-11 (condensed) -->
  <link name="segment_4"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.015" length="0.048"/></geometry><material name="worm_body"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.015" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_3" type="revolute"><parent link="segment_3"/><child link="segment_4"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_5"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.014" length="0.048"/></geometry><material name="worm_body"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.014" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_4" type="revolute"><parent link="segment_4"/><child link="segment_5"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_6"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.013" length="0.048"/></geometry><material name="worm_dark"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.013" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_5" type="revolute"><parent link="segment_5"/><child link="segment_6"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_7"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.012" length="0.048"/></geometry><material name="worm_dark"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.012" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_6" type="revolute"><parent link="segment_6"/><child link="segment_7"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_8"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.011" length="0.048"/></geometry><material name="worm_dark"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.011" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_7" type="revolute"><parent link="segment_7"/><child link="segment_8"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_9"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.010" length="0.048"/></geometry><material name="worm_dark"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.010" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_8" type="revolute"><parent link="segment_8"/><child link="segment_9"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_10"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.009" length="0.048"/></geometry><material name="worm_dark"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.009" length="0.048"/></geometry></origin></collision>
    <inertial><mass value="0.001"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_9" type="revolute"><parent link="segment_9"/><child link="segment_10"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <link name="segment_11"><visual><origin xyz="0 0 0" rpy="0 1.5708 0"/>
    <geometry><cylinder radius="0.007" length="0.040"/></geometry><material name="worm_dark"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 1.5708 0"><geometry><cylinder radius="0.007" length="0.040"/></geometry></origin></collision>
    <inertial><mass value="0.0005"/><inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7"/></inertial></link>
  <joint name="joint_10" type="revolute"><parent link="segment_10"/><child link="segment_11"/>
    <origin xyz="-0.05 0 0"/><axis xyz="0 0 1"/>
    <limit lower="-0.8" upper="0.8" effort="0.01" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.01"/></joint>

  <!-- Gazebo friction properties -->
  <gazebo reference="segment_0">
    <material>Gazebo/Green</material>
    <mu1>0.8</mu1><mu2>0.8</mu2>
  </gazebo>
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher"
            filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>50</update_rate>
      <joint_name>joint_0</joint_name>
      <joint_name>joint_1</joint_name>
      <joint_name>joint_2</joint_name>
      <joint_name>joint_3</joint_name>
      <joint_name>joint_4</joint_name>
      <joint_name>joint_5</joint_name>
      <joint_name>joint_6</joint_name>
      <joint_name>joint_7</joint_name>
      <joint_name>joint_8</joint_name>
      <joint_name>joint_9</joint_name>
      <joint_name>joint_10</joint_name>
    </plugin>
  </gazebo>

</robot>
